{
  "manifest_version": 3,
  "name": "Smooth Surfer",
  "version": "0.2.1",
  "description": "Surf the web with only the waves you want.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "Smooth Surfer",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": ["src/styles.css"],
      "js": ["src/settings.js", "src/storage.js", "src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
