{
  "manifest_version": 3,
  "name": "Smooth Surfer",
  "version": "0.1.0",
  "description": "Surf the web with only the waves you want.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://m.youtube.com/*",
    "https://x.com/*",
    "https://www.x.com/*",
    "https://twitter.com/*",
    "https://www.twitter.com/*",
    "https://mobile.twitter.com/*",
    "https://reddit.com/*",
    "https://*.reddit.com/*",
    "https://substack.com/*",
    "https://*.substack.com/*",
    "https://news.ycombinator.com/*",
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "Smooth Surfer",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": ["src/styles.css"],
      "js": ["src/settings.js", "src/storage.js", "src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
